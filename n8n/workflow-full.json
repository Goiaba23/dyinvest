{
  "name": "Data Sync - Full",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Every 1 Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://localhost:3000/api/sync?action=sync",
        "options": {
          "timeout": 60000
        }
      },
      "id": "sync",
      "name": "Sync All Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://localhost:3000/api/sync?action=crypto",
        "options": {
          "timeout": 30000
        }
      },
      "id": "crypto",
      "name": "Get Crypto",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [750, 300]
    }
  ],
  "connections": {
    "Every 1 Hour": {
      "main": [
        [
          {
            "node": "Sync All Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Sync All Data": {
      "main": [
        [
          {
            "node": "Get Crypto",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {},
  "staticData": null,
  "tags": ["investimento", "sync"]
}