{
  "name": "Complete Sync - All Data",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "id": "schedule",
      "name": "Every 30 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/sync?action=sync",
        "options": {
          "timeout": 60000
        }
      },
      "id": "sync",
      "name": "1. Sync Stocks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/sync?action=crypto",
        "options": {
          "timeout": 30000
        }
      },
      "id": "crypto",
      "name": "2. Get Crypto",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/ai?action=full_analysis",
        "options": {
          "timeout": 60000
        }
      },
      "id": "ai",
      "name": "3. AI Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [750, 300]
    }
  ],
  "connections": {
    "Every 30 Minutes": {
      "main": [
        [
          { "node": "1. Sync Stocks", "type": "main", "index": 0 },
          { "node": "2. Get Crypto", "type": "main", "index": 0 }
        ]
      ]
    },
    "1. Sync Stocks": {
      "main": [
        [
          { "node": "3. AI Analysis", "type": "main", "index": 0 }
        ]
      ]
    },
    "2. Get Crypto": {
      "main": [
        [
          { "node": "3. AI Analysis", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "settings": {},
  "staticData": null,
  "tags": ["investimento", "complete", "realtime"]
}