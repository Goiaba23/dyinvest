{
  "name": "MASTER - Ultimate 1",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "id": "schedule",
      "name": "Every 30 Min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": "1.1",
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/market-hours?action=status",
        "options": { "timeout": 10000 }
      },
      "id": "market-hours",
      "name": "1. Check Market",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [500, 150]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/sync?action=sync",
        "options": { "timeout": 60000 }
      },
      "id": "sync-stocks",
      "name": "2. Sync Stocks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [750, 100]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/sync?action=crypto",
        "options": { "timeout": 30000 }
      },
      "id": "sync-crypto",
      "name": "3. Sync Crypto",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [750, 250]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/scraped?action=gainers",
        "options": { "timeout": 30000 }
      },
      "id": "scraped",
      "name": "4. Scraped Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [750, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/economic?action=overview",
        "options": { "timeout": 15000 }
      },
      "id": "economic",
      "name": "5. Economic Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1000, 150]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/news?ativo=IBOV&tipo=noticias",
        "options": { "timeout": 30000 }
      },
      "id": "news",
      "name": "6. News",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/ai?action=full_analysis",
        "options": { "timeout": 60000 }
      },
      "id": "ai",
      "name": "7. AI Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1250, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3000/api/portfolio?action=recommendations",
        "options": { "timeout": 30000 }
      },
      "id": "portfolio",
      "name": "8. Portfolio",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1250, 400]
    }
  ],
  "connections": {
    "Every 30 Min": {
      "main": [
        [{ "node": "1. Check Market", "type": "main", "index": 0 }]
      ]
    },
    "1. Check Market": {
      "main": [
        [{ "node": "2. Sync Stocks", "type": "main", "index": 0 }],
        [{ "node": "3. Sync Crypto", "type": "main", "index": 0 }],
        [{ "node": "4. Scraped Data", "type": "main", "index": 0 }]
      ]
    },
    "2. Sync Stocks": {
      "main": [
        [{ "node": "5. Economic Data", "type": "main", "index": 0 }]
      ]
    },
    "3. Sync Crypto": {
      "main": [
        [{ "node": "5. Economic Data", "type": "main", "index": 0 }]
      ]
    },
    "4. Scraped Data": {
      "main": [
        [{ "node": "5. Economic Data", "type": "main", "index": 0 }]
      ]
    },
    "5. Economic Data": {
      "main": [
        [{ "node": "6. News", "type": "main", "index": 0 }]
      ]
    },
    "6. News": {
      "main": [
        [{ "node": "7. AI Analysis", "type": "main", "index": 0 }]
      ]
    },
    "7. AI Analysis": {
      "main": [
        [{ "node": "8. Portfolio", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {},
  "staticData": null,
  "tags": ["investimento", "master", "ultimate", "economic"],
  "activationMode": "manual"
